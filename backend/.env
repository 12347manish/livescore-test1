
# ===== SPORTMONKS API CONFIGURATION =====
SPORTMONKS_API_KEY=your_api_key_here
SPORTMONKS_BASE_URL=https://api.sportmonks.com
SPORTMONKS_TIMEOUT=5000

# ===== REDIS CONFIGURATION =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=10
REDIS_RETRY_DELAY=100

# ===== OPTIMIZED CACHE CONFIGURATION - ZERO LATENCY =====
# NEW: 15, 45, 900, 10 (much shorter for real-time)

# Live Scores - ULTRA SHORT (15 seconds)
CACHE_LIVE_SCORES_TTL=15

# Match Details - SHORT (45 seconds)
CACHE_MATCH_DETAILS_TTL=45

# Match Events - MEDIUM (15 minutes)
CACHE_EVENTS_TTL=900

# Match Status - CRITICAL (10 seconds) - NEW for trading
CACHE_MATCH_STATUS_TTL=10

# ===== POLLING CONFIGURATION =====
# When LIVE matches exist - poll every 1 second (faster)
POLLING_INTERVAL_LIVE=1000

# When NO LIVE matches - poll every 10 seconds (slower, save quota)
POLLING_INTERVAL_NO_LIVE=10000

# ===== WEBHOOK CONFIGURATION =====
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_RETRY_ATTEMPTS=5
WEBHOOK_RETRY_DELAY=200

# ===== SERVER CONFIGURATION =====
NODE_ENV=production
SERVER_PORT=3001
SERVER_HOST=0.0.0.0

# ===== PERFORMANCE TRACKING =====
ENABLE_LATENCY_TRACKING=true
LATENCY_LOG_THRESHOLD=50
ENABLE_COMPRESSION=true

# ===== WEBSOCKET CONFIGURATION =====
WEBSOCKET_PING_INTERVAL=25000
WEBSOCKET_PING_TIMEOUT=60000
MAX_CONNECTIONS=1000
USE_DUMMY_DATA=true
